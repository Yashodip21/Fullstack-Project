<%layout("/layouts/boilerplate")%>
<style>
    #filters {
        display: flex;
        flex-wrap: wrap;
       
        margin-top: 1rem;
        align-items: center;
    }

    .filter {
        text-align: center;
        margin-right: 1rem;
        margin-top: 1rem;
        opacity: 0.7;
        /* width: 80px; */
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }
    .filter p{
        font-size:0.8rem;
    }
    @media (max-width:768px){

.filter{
display:none;
}

.filter:nth-child(-n+5){
display:block;
}

}
.tax-info{
    font-size:0.7rem;
    color:gray;
    display: none;
}
.tax-toggle{

    border: 1px solid black;
    border-radius: 1rem;
    height: 3.2rem;
    padding: 1rem;
    margin-left:3rem;

    display: flex;
    align-items: center;

}
.btn-back{
background-color:#fe424d;
color:white;
border:none;
}

.btn-back:hover{
background-color:#e0313b;
color:white;
}
</style>



    <div id="filters"class="d-flex flex-wrap gap-3">
        <div class="filter">
         <div>  <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
         </div>

        </div>
        <div class="filter">
         <div>   <i class="fa-solid fa-bed"></i>
            <p>Rooms</p>
         </div>
        </div>
        <div class="filter">
          <div>  <i class="fa-solid fa-mountain-city"></i>
                <p>Iconic City</p>
            </div>
        
        </div>
        <div class="filter">
            <div> <i class="fa-solid fa-mountain"></i>
                <p>Mountains</p>
            </div>
        
        </div>
        <div class="filter">
            <div> <i class="fa-brands fa-fort-awesome"></i>
                <p>Castles</p>
            </div>
        
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i>
                <p>Amazing Pools</p>
            </div>
        
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-campground"></i>
                <p>Camping</p>
            </div>
        
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-tractor"></i>
                <p>Farms</p>
            </div>
        
        </div>
        <div class="filter">
            <div><i class="fa-regular fa-snowflake"></i>
                <p>Arctic</p>
            </div>
        
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-igloo"></i>
                <p>Dome</p>
            </div>
        
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-sailboat"></i>
                <p>Boats</p>
            </div>
        
        </div>
        <div class="tax-toggle">
            <div class="form-check form-switch form-check-reverse">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>

        </div>

    </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
<% if(allListings.length===0){ %>

    <h3 class="text-center mt-5">No Listings Found </h3>
    <div class="text-center">
        <a href="/listings" class="btn btn-back mt-3">Back to all listings</a>
    </div>

    <% } else { %>

        <% for(let listing of allListings){ %>

            <a href="/listings/<%=listing._id%>" class="listing-link">

                <div class="card col listing-card">

                    <img src="<%= listing.image.url %>"
                        onerror="this.src='https://images.unsplash.com/photo-1507525428034-b723cf961d3e'"
                        class="card-img-top" style="height:20rem;">

                    <div class="card-img-overlay"></div>

                    <div class="card-body">
                        <p class="card-text">

                            <b>
                                <%= listing.title %>
                            </b>
                            <br>

                            &#8377;
                            <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
                                / Night

                                <i class="tax-info">&nbsp; &nbsp;+18% GST</i>

                        </p>
                    </div>

                </div>

            </a>

            <% } %>

                <% } %>
    </div>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () =>{
        let taxInfo=document.getElementsByClassName("tax-info"); 
        for(info of taxInfo ){
           if(info.style.display!="inline"){
            info.style.display="inline";     
        }else{
            info.style.display="none";
            
        }
            
        }});
        
    </script>
    



