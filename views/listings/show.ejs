<% layout("/layouts/boilerplate") %>

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8 offset-md-2">

                <h3 class="mb-4"><%= listing.title %></h3>

                <!-- Card -->
                <div class="card mb-4 listing-card">

                    <!-- Image -->
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image"
                        style="height: 300px; object-fit: cover;">

                    <div class="card-body">

                      
                        <p class="card-text text-muted">
                            <%= listing.description %>
                        </p>

                        <p class="fs-5 fw-bold">
                        &#8377;
                        <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>

                        </p>

                        <p class="text-secondary mb-4">
                            <i class="bi bi-geo-alt"></i>
                            <%= listing.location %>, <%= listing.country %>
                        </p>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">

                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">
                                Edit
                            </a>

                            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE"
                                onsubmit="return confirm('Are you sure you want to delete this listing?');">
                                <button class="btn btn-danger">
                                    Delete
                                </button>
                            </form>

                        </div>

                    </div>
                </div>

                <!-- Back -->
                <a href="/listings" class="btn btn-outline-secondary">
                    ← Back to Listings
                </a>

            </div>
        
        </div>
        <br><br>

        <div class="col-md-8 offset-md-2">
            <hr>
            <h4>Leave a review</h4>
            <form action="/listings/<%= listing.id%>/reviews" method="POST" novalidate class="needs-validation">
                <div class="mb=3 mt-3"> 
                    <label for="rating" class="form-label">Rating</label>
                     <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range" >
                </div>
                <div class="mb=3 mt-3">
                    <lable for="comment" class="form-label" required>Comment</lable>
                    <textarea name="review[comment]" 
                    id="comment" 
                    cols="30" 
                    rows="5" 
                    class="form-control"
                    required
                    
                    ></textarea>
                    <div class="invalid-feedback">please submit some comments for review</div>
                </div>
                <br>
                <button class="btn btn-outline-dark"> Submit</button>
            </form>

            <hr>

            <p><b>All Reviews</b></p>

            <div class="row">
            <% for(review of listing.reviews){%>
            <div class="card col-5 ms-2 mb-3">
                <div class="card-body">
                    <h5 class="card-title">Cyash</h5>
                        <p class="card-text"><%=review.comment%></p>
                        <p class="card-text"> <%=review.rating%></p>
                </div>
                 <form class="mb-3" method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE"> 
                    <button clas="btn btn-sm btn-dark">Delete</button>
                 </form>
                 </div>
        
            <%}%>
            </div>
            
        </div>
    </div>